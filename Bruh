        users_state[user_id] = 'start' # Holatni tozalash

# ==================== ADMIN QISMI ====================
@bot.callback_query_handler(func=lambda call: call.data.startswith("admin_"))
def admin_action(call):
    admin_id = call.from_user.id
    if admin_id not in ADMINS: return
    
    parts = call.data.split('_')
    action = parts[1]
    target_user_id = int(parts[2])
    
    if action == "accept":
        bot.edit_message_caption("✅ Qabul qilindi!", chat_id=call.message.chat.id, message_id=call.message.message_id, reply_markup=None)
        try:
            bot.send_message(target_user_id, "Chek qabul qilindi✓ Biroz kuting robux tushmoqda..")
        except:
            bot.answer_callback_query(call.id, "Foydalanuvchiga xabar borishda xatolik!")
            
    elif action == "reject":
        admin_state[admin_id] = {'action': 'reject', 'user_id': target_user_id}
        bot.send_message(admin_id, f"Rad etish sababini kiriting (User ID: {target_user_id}):")
        bot.edit_message_caption("❌ Rad etildi.", chat_id=call.message.chat.id, message_id=call.message.message_id, reply_markup=None)
        
    elif action == "block":
        admin_state[admin_id] = {'action': 'block', 'user_id': target_user_id}
        bot.send_message(admin_id, f"Bloklash sababini kiriting (User ID: {target_user_id}):")
        bot.edit_message_caption("🚫 Bloklandi.", chat_id=call.message.chat.id, message_id=call.message.message_id, reply_markup=None)

@bot.message_handler(func=lambda message: message.from_user.id in ADMINS and message.from_user.id in admin_state)
def admin_reason_handler(message):
    admin_id = message.from_user.id
    state_info = admin_state[admin_id]
    action = state_info['action']
    target_user_id = state_info['user_id']
    reason = message.text
    
    if action == 'reject':
        try:
            bot.send_message(target_user_id, f"Buyurtmangiz rad etildi.\nSabab: {reason}")
            bot.send_message(admin_id, "Foydalanuvchiga sabab yuborildi.")
        except:
            bot.send_message(admin_id, "Foydalanuvchi botni bloklagan bo'lishi mumkin.")
            
    elif action == 'block':
        blacklist.add(target_user_id) # Qora ro'yxatga qo'shish
        try:
            bot.send_message(target_user_id, f"Siz botdan bloklandingiz.\nSabab: {reason}")
        except:
            pass
        bot.send_message(admin_id, "Foydalanuvchi bloklandi va unga sabab yuborildi. U qora ro'yxatga kiritildi.")
        
    # Admin holatini tozalash
    del admin_state[admin_id]

